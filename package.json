{
  "name": "@flprog/edit-app",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://phazz1980.github.io/Flprog_WebUI_Editor",
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.126",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "konva": "^10.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-konva": "^19.2.3",
    "react-scripts": "5.0.1",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4",
    "zustand": "^5.0.11"
  },
  "scripts": {
    "start": "concurrently -k -n editor,viewer,proxy -c blue,green,magenta \"npm run start:editor\" \"npm run start:viewer\" \"wait-on http://127.0.0.1:3001 http://127.0.0.1:3002 -t 90000 && node server/devProxy.js\"",
    "start:editor": "cross-env PORT=3001 BROWSER=none react-scripts start",
    "start:viewer": "cd viewer && cross-env PORT=3002 PUBLIC_URL=/Flprog_WebUI_Editor/viewer BROWSER=none npm start",
    "start:editor-only": "react-scripts start",
    "build": "node scripts/set-build-date.js && react-scripts build",
    "build:relative": "node scripts/set-build-date.js && cross-env PUBLIC_URL=. react-scripts build",
    "build:with-viewer": "npm run build && node scripts/build-viewer-into-build.js",
    "build:with-viewer:relative": "npm run build:relative && node scripts/build-viewer-into-build.js",
    "test": "react-scripts test",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d build",
    "deploy:with-viewer": "npm run build:with-viewer && gh-pages -d build",
    "simulator": "node server/simulatorServer.js",
    "build:simulator-exe": "pkg server/simulatorServer.js --targets node18-win-x64 --output dist/FlprogSimulator.exe"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "gh-pages": "^6.3.0",
    "pkg": "^5.8.1",
    "wait-on": "^8.0.1"
  }
}
